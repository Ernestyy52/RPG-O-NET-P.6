{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Generated Asset Manifest (sidecar)",
  "description": "Provenance sidecar for every generated output (Setup Pack §15).",
  "type": "object",
  "required": ["assetId", "jobId", "status", "assetType", "files", "generation", "validation", "license"],
  "additionalProperties": true,
  "properties": {
    "assetId": { "type": "string", "pattern": "^generated\\.[a-z0-9._-]+$" },
    "jobId": { "type": "string" },
    "status": { "type": "string", "enum": ["candidate", "approved", "rejected"] },
    "assetType": { "type": "string" },
    "files": {
      "type": "object",
      "required": ["source"],
      "properties": {
        "source": { "type": "string" },
        "processed": { "type": ["string", "null"] }
      }
    },
    "generation": {
      "type": "object",
      "required": ["workflowId", "modelId", "seed", "positivePromptHash", "negativePromptHash", "generatedAt"],
      "properties": {
        "workflowId": { "type": "string" },
        "workflowHash": { "type": ["string", "null"] },
        "modelId": { "type": ["string", "null"] },
        "modelHash": { "type": ["string", "null"] },
        "seed": { "type": "integer" },
        "positivePromptHash": { "type": "string" },
        "negativePromptHash": { "type": "string" },
        "generatedAt": { "type": "string" }
      }
    },
    "validation": {
      "type": "object",
      "required": ["technicalPassed", "artPassed", "integrationPassed"],
      "properties": {
        "technicalPassed": { "type": "boolean" },
        "artPassed": { "type": "boolean" },
        "integrationPassed": { "type": "boolean" },
        "issues": { "type": "array", "items": { "type": "string" } }
      }
    },
    "license": {
      "type": "object",
      "required": ["commercialUseChecked", "redistributionChecked"],
      "properties": {
        "modelLicense": { "type": "string" },
        "commercialUseChecked": { "type": "boolean" },
        "redistributionChecked": { "type": "boolean" }
      }
    }
  }
}
