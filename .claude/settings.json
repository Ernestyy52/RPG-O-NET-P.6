{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git branch *)",
      "Bash(git rev-list *)",
      "Bash(git check-ignore *)",
      "Bash(npm run build)",
      "Bash(npm run generate)",
      "Bash(npm run test *)",
      "Bash(npm test *)",
      "Bash(npx vitest *)",
      "Bash(npm ls *)"
    ],
    "deny": [
      "Bash(git push --force*)",
      "Bash(git push -f*)"
    ]
  }
}
